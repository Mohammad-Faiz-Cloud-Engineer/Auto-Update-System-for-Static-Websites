{
  "name": "auto-update-system",
  "version": "2.2.0",
  "description": "Production-grade auto-update system for static HTML/CSS/JS websites",
  "main": "dist/auto-update.js",
  "types": "types/auto-update.d.ts",
  "files": [
    "dist/",
    "types/",
    "integrations/",
    "plugins/",
    "examples/"
  ],
  "scripts": {
    "test": "node test/run-tests.js",
    "test:security": "node test/security-tests.js",
    "test:integration": "node test/integration-tests.js",
    "test:v2.2": "node test/v2.2-tests.js",
    "test:all": "npm run test && npm run test:security && npm run test:integration && npm run test:v2.2",
    "build": "node src/build-version.js patch",
    "build:minor": "node src/build-version.js minor",
    "build:major": "node src/build-version.js major",
    "dist": "cp src/auto-update.js dist/ && cp types/auto-update.d.ts dist/",
    "serve": "npx http-server -p 8080 -c-1",
    "dev": "npx http-server -p 8080 -c-1 --open test/index.html"
  },
  "keywords": [
    "auto-update",
    "hot-reload",
    "cache-busting",
    "version-control",
    "static-site",
    "pwa",
    "service-worker",
    "update-notification",
    "react",
    "vue",
    "angular",
    "webpack",
    "vite",
    "typescript"
  ],
  "author": "Mohammad Faiz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mohammad-Faiz-Cloud-Engineer/Auto-Update-System-for-Static-Websites.git"
  },
  "bugs": {
    "url": "https://github.com/Mohammad-Faiz-Cloud-Engineer/Auto-Update-System-for-Static-Websites/issues"
  },
  "homepage": "https://github.com/Mohammad-Faiz-Cloud-Engineer/Auto-Update-System-for-Static-Websites#readme",
  "devDependencies": {},
  "engines": {
    "node": ">=12.0.0"
  }
}
